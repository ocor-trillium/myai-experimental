# =============================================================================
# Variables públicas del cliente
#
# IMPORTANTE
#   - Solo variables con prefijo VITE_ son embebidas en el bundle del navegador.
#   - Cualquier valor expuesto al cliente debe considerarse PÚBLICO.
#   - NUNCA pongas API keys, tokens, secretos o credenciales aquí.
#   - Usa un backend / BFF para manejar secretos y firmar peticiones.
# =============================================================================

# Identificador de entorno: development | staging | production
VITE_APP_ENV=development

# Versión visible para diagnóstico (idealmente inyectada por CI desde la tag)
VITE_APP_VERSION=0.1.0

# URL base del backend / API. En producción suele ser un path relativo
# detrás de un reverse proxy (ej. /api), o un dominio dedicado HTTPS.
VITE_API_BASE_URL=/api

# Puerto del servidor de desarrollo (opcional)
VITE_DEV_PORT=5173
